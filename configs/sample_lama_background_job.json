{
  "schema_version": "1.0",
  "project_name": "sample_dashboard_restyle_lama_background",
  "base_image": "examples/base_placeholder.svg",
  "target_elements": [
    {
      "id": "primary_button",
      "name": "primary action button",
      "type_hint": "button",
      "action": "replace_style",
      "style": "glassmorphism blue accent",
      "keep_text": true
    },
    {
      "id": "stat_cards",
      "name": "dashboard stat cards",
      "type_hint": "card",
      "action": "restyle",
      "style": "minimal dark dashboard cards",
      "keep_text": true
    }
  ],
  "algorithms": {
    "detector": "lightweight_detector",
    "segmenter": "placeholder_segmenter",
    "ocr": "placeholder_ocr",
    "background_repair": "lama_background_inpaint",
    "style": "lightweight_style_transfer",
    "review": "contract_review"
  },
  "global_style": {
    "description": "quiet enterprise dashboard with crisp spacing",
    "palette": ["#111827", "#2563EB", "#22C55E"],
    "corner_radius": 10,
    "shadow": "soft"
  },
  "output": {
    "formats": ["image", "json"],
    "preserve_layout": false
  }
}
